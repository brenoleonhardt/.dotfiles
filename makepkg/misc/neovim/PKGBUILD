# shellcheck disable=all

pkgname=neovim-fork
pkgver=0.12.0
pkgrel=2560
pkgdesc='Fork of Vim aiming to improve user experience, plugins, and GUIs.'
arch=('x86_64')
url='https://neovim.io'
license=('custom:neovim')
conflicts=('neovim')
options=('!debug')

source=()
sha256sums=()

prepare() {
	curl -L -H "Accept: application/octet-stream" \
		-o "${srcdir}/nvim-linux-x86_64.tar.gz" \
		"https://api.github.com/repos/neovim/neovim/releases/assets/372887746"

	echo "b7215fcabd04b53188035c7f4ef32693308ca0fa88ebf016355a8ca9f292f926  ${srcdir}/nvim-linux-x86_64.tar.gz" | sha256sum -c -

	tar -xzf "${srcdir}/nvim-linux-x86_64.tar.gz" -C "${srcdir}"
}

check() {
	cd "${srcdir}/nvim-linux-x86_64"
	./bin/nvim --version
	./bin/nvim --headless -u NONE -i NONE -c ':quit'
}

package() {
	cd "${srcdir}/nvim-linux-x86_64"
	install -Dm755 bin/nvim -t "$pkgdir/usr/bin/"
	cp -r lib "$pkgdir/usr/"
	cp -r share "$pkgdir/usr/"
}
