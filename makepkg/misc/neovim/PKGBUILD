# shellcheck disable=all

pkgname=neovim-fork
pkgver=0.11.6
pkgrel=0
pkgdesc='Fork of Vim aiming to improve user experience, plugins, and GUIs.'
arch=(x86_64)
url='https://neovim.io'
license=('custom:neovim')
conflicts=(neovim)
options=('!debug')

source=("https://github.com/neovim/neovim/releases/download/nightly/nvim-linux-x86_64.tar.gz")

sha256sums=('2fc90b962327f73a78afbfb8203fd19db8db9cdf4ee5e2bef84704339add89cc')

check() {
  cd nvim-linux-x86_64
  ./bin/nvim --version
  ./bin/nvim --headless -u NONE -i NONE -c ':quit'
}

package() {
  cd nvim-linux-x86_64
  install -Dm755 bin/nvim -t "$pkgdir/usr/bin/"
  cp -r lib share "$pkgdir/usr/"
}
