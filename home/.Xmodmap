! TODO:
! move this to kinata or something that supports spacebar as GUI homerow

clear lock
clear mod1
clear mod2
clear mod3
clear mod4
clear mod5
clear control
clear shift

keycode 66  = Control_L
keycode 108 = Shift_L

! left <> on lenovo ideapad
keycode 94  = backslash bar asciitilde apostrophe

add control = Control_L Control_R
add shift   = Shift_L Shift_R
add mod1    = Alt_L
add mod4    = Super_L
