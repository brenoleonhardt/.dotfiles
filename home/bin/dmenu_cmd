#!/usr/bin/env bash
set -euo pipefail

commands=(
	burn-iso
	clone-github
	dmenu_apps
	dmenu_cmd
	dmenu_pass
	dmenu_pdf
	dmenu_session
	dmenu_usb
	dmenu_window
	faillock-reset
	"monitor -i"
	reset-audio
	reset-keyboard
	reset-mbsync
	# sketch is not interactive
	st-notes
	xev-lofree
)
command=$(printf "%s\n" "${commands[@]}" | ~/Downloads/dmenu-5.4/dmenu -p "Command")
eval "$command"
