#!/usr/bin/env python

import subprocess
import evdev
from evdev import ecodes
import setproctitle

setproctitle.setproctitle("notify-capslock")

devices = [evdev.InputDevice(path) for path in evdev.list_devices()]

keyboard = None
for d in devices:
    if ecodes.EV_LED in d.capabilities() and ecodes.EV_KEY in d.capabilities():
        keyboard = d
        break

for event in keyboard.read_loop():
    if event.type == ecodes.EV_LED:
        if event.code == ecodes.LED_CAPSL:
            state = "ON" if event.value else "OFF"
            subprocess.run([
                "notify-send",
                "-i", "input-keyboard",
                "-r", "39621",
                keyboard.name,
                f"Caps Lock: {state}"
            ])
